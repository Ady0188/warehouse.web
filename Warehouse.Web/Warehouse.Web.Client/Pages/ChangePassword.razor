@page "/Account/ResetPassword"

@rendermode InteractiveAuto

@using System.ComponentModel.DataAnnotations
@using Warehouse.Web.Client.Layout
@using System.Text.Json
@using System.Text

@inject NavigationManager NavigationManager
@inject HttpClient client

@layout LoginLayout

<PageTitle>Вход</PageTitle>

<MudGrid Justify="Justify.Center">
    <MudItem md="2">
        <MudCard Style="padding: 20px; margin-top: 50px;">
            <EditForm Model="Input" FormName="reset-password" OnValidSubmit="ResetPass">
                <DataAnnotationsValidator />

                <MudStack Justify="Justify.Center">
                    <MudIcon Icon="@Icons.Material.Outlined.Person" Style="margin-left:auto;margin-right:auto;font-size:6rem;" Title="Favorite" />
                </MudStack>

                <MudGrid Style="margin-bottom: 10px;">
                    <MudItem md="12">
                        <MudTextField For="@(() => Input.Username)" @bind-Value="Input.Username" Disabled Required
                                      Label="Логин" Placeholder="Введите логин"
                                      UserAttributes="@(new() { { "autocomplete", "true" }, { "aria-required", "true" } })" />
                    </MudItem>
                    <MudItem md="12">
                        <MudTextField For="@(() => Input.Password)" @bind-Value="Input.Password" Required
                                      Label="Новый пароль" InputType="InputType.Password" Placeholder="Введите пароль"
                                      UserAttributes="@(new() { { "autocomplete", "current-password" }, { "aria-required", "true" } })" />
                    </MudItem>

                    <MudItem md="12">
                        <MudTextField For="@(() => Input.ConfirmPassword)" @bind-Value="Input.ConfirmPassword" Required
                                      Label="Подтверждение парля" InputType="InputType.Password" Placeholder="Введите пароль"
                                      UserAttributes="@(new() { { "autocomplete", "current-password" }, { "aria-required", "true" } })" />
                    </MudItem>
                    <MudItem md="12">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" ButtonType="ButtonType.Submit">Сохранить</MudButton>
                    </MudItem>
                </MudGrid>

                <StatusMessage Message="@errorMessage" IsSuccess=isSuccess />
            </EditForm>
        </MudCard>
    </MudItem>
</MudGrid>

@code {

    private string? errorMessage;
    private bool isSuccess = true;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    private string? Login { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Input.Username = Login;
    }

    private async Task ResetPass()
    {
        if (string.IsNullOrEmpty(Input.Password) || string.IsNullOrEmpty(Input.ConfirmPassword))
        {
            isSuccess = false;
            errorMessage = "Пароль и подтверждение пароля не должны быть пусты";
            return;
        }
        else if (!Input.Password.Equals(Input.ConfirmPassword))
        {
            isSuccess = false;
            errorMessage = "Пароль и подтверждение пароля не совпадают";
            return;
        }
        else if (Input.Password.Equals(Input.ConfirmPassword))
        {
            isSuccess = true;
            errorMessage = "OK!";

            var request = new ChangePasswordRequest
                {
                    Username = Input.Username,
                    Password = Input.Password,
                    ConfirmPassword = Input.ConfirmPassword
                };

            var response = await client.PostAsync(ApiEndpoints.V1.Users.ChangePassword, new StringContent(JsonSerializer.Serialize(Input), Encoding.UTF8, "application/json"));

            if (response.IsSuccessStatusCode)
            {
                NavigationManager.NavigateTo("Account/Login");
            }
        }
    }

    private sealed class InputModel
    {
        [Required(ErrorMessage = "Необходимо указать логин.")]
        public string Username { get; set; } = "";

        [Required(ErrorMessage = "Необходимо указать пароль.")]
        [DataType(DataType.Password)]
        [RegularExpression(@"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^\da-zA-Z]).{8,}$", ErrorMessage = "Пароль должен содержать минимум 8 символов, включая заглавную, строчную букву, цифру и спецсимвол.")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Необходимо указать подтверждение пароля.")]
        [DataType(DataType.Password)]
        public string ConfirmPassword { get; set; } = "";

        [Display(Name = "Remember me?")]
        public bool RememberMe { get; set; }
    }
}
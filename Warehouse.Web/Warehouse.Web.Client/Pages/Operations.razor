    private async Task ApplyFilter()
    {
        filterString = filter.ToString();

        await table.ReloadServerData();

        _filterExpanded = false;
        filterVariant = filter.IsEmpty ? Variant.Outlined : Variant.Filled;
    }

    bool _resetToToday { get; set; }

    private async Task ResetFilter()
    {
        filter = new();

        _resetToToday = true;
        await Task.Delay(1);
        _resetToToday = false;

        await ApplyFilter();
    }

    string GetTitle(string? path)
    {
        if (string.Equals(kind, "send", StringComparison.OrdinalIgnoreCase))
            return "Отправка";
        else if (string.Equals(kind, "receive", StringComparison.OrdinalIgnoreCase))
            return "Получение";
        else if (string.Equals(kind, "receiving", StringComparison.OrdinalIgnoreCase))
            return "Приемки";
        else if (string.Equals(kind, "returntosuplier", StringComparison.OrdinalIgnoreCase))
            return "Возвраты поставщикам";
        else if (string.Equals(kind, "shipments", StringComparison.OrdinalIgnoreCase))
            return "Отгрузки";

        return "Возвраты покупателей";
    }

    OperationType GetType(string? path)
    {
        if (string.Equals(kind, "send", StringComparison.OrdinalIgnoreCase))
            return OperationType.Send;
        else if (string.Equals(kind, "receive", StringComparison.OrdinalIgnoreCase))
            return OperationType.Receive;
        else if (string.Equals(kind, "receiving", StringComparison.OrdinalIgnoreCase))
            return OperationType.Receiving;
        else if (string.Equals(kind, "returntosuplier", StringComparison.OrdinalIgnoreCase))
            return OperationType.ReturnsToSuplier;
        else if (string.Equals(kind, "shipments", StringComparison.OrdinalIgnoreCase))
            return OperationType.Shipments;

        return OperationType.BuyerReturn;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (table is not null && (string.Equals(kind, "send", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(kind, "receive", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(kind, "receiving", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(kind, "returntosuplier", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(kind, "shipments", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(kind, "buyerreturn", StringComparison.OrdinalIgnoreCase)))
        {
            Columns = await LocalStorage.GetOperationColumns(type);

            await ResetFilter();
        }
    }


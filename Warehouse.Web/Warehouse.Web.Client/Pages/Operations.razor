@page "/operations/{kind}"

@inject HttpClient client
@inject IJSRuntime JSRuntime

@attribute [Authorize(Roles = "Admin,User")]

<PageContent Title=@Title @ref=pageContent FilterExpanded=@_filterExpanded OnApplyFilter="ApplyFilter" OnResetFilter="ResetFilter">
    <ActionBar>
        <MudButton Variant=@filterVariant Size="Size.Small" Color="Color.Info" StartIcon=@Icons.Material.Filled.FilterAlt OnClick=@(() => _filterExpanded = true)>Фильтр</MudButton>
        <MudButton Variant=Variant.Outlined Size="Size.Small" Color="Color.Info" StartIcon=@Icons.Custom.FileFormats.FileExcel OnClick=@ExportToExcel Disabled=!canExport>Экспорт в Excel</MudButton>
        <AuthorizeView Roles="User">
            @if (type == OperationType.Send)
            {
                <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Primary" StartIcon=@Icons.Material.Filled.CallMade OnClick="OpenAddDialogAsync">Отправить</MudButton>
            }
            else if (type == OperationType.Receive)
            {
                <MudBadge Content=@count Color="Color.Primary" Overlap="true" Class="mx-6 my-4">
                    <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Primary" StartIcon=@Icons.Material.Filled.CallReceived Disabled=@(count == 0) OnClick=@(_ => count > 0 ? OpenEditDialogAsync(notReceivedList.First()) : OpenAddDialogAsync())>Получить</MudButton>
                </MudBadge>
            }
            else
            {
                <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Primary" StartIcon=@Icons.Material.Filled.Add OnClick="OpenAddDialogAsync">Добавить</MudButton>
            }
        </AuthorizeView>
        <AuthorizeView Roles="Admin">
            @if (type == OperationType.Receiving || type == OperationType.ReturnsToSuplier)
            {
                <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Primary" StartIcon=@Icons.Material.Filled.Add OnClick="OpenAddDialogAsync">Добавить</MudButton>
            }
        </AuthorizeView>
    </ActionBar>
    <FilterBar>
        <MudGrid Style="padding: 0 0 10px 0;">
            <MudItem xs="1">
                <MudNumericField @bind-Value=@filter.Code Label="Код" Clearable />
            </MudItem>
            <MudItem xs="3">
                @* <PeriodFilter PeriodChanged="OnPeriodChanged" ResetToToday=_resetToToday /> *@
                <MonthPicker PastYears="pastYears" PeriodChanged="OnPeriodChanged" ResetToToday=_resetToToday />
                @* <MudDateRangePicker Label="Период" DateFormat="dd.MM.yyyy" PickerVariant="PickerVariant.Dialog" @bind-DateRange="@filter.DateRange" Margin="Margin.Dense" /> *@
            </MudItem>
            @if (type != OperationType.Send && type != OperationType.Receive)
            {
                <MudItem xs="2">
                    <MyMudSelect TItem="long" @bind-Value=@filter.StoreId Label="Склад" Items=@stores Clearable Dense />
                </MudItem>
                <MudItem xs="3">
                    <MyMudSelect TItem="long" @bind-Value=@filter.ManagerId Label="Менеджер" Items=@_managers Clearable Dense />
                </MudItem>
                <MudItem xs="3">
                    <MyMudSelect TItem="long" @bind-Value=@filter.AgentId Label="Контрагент" Items=@_agents Searchable Clearable Dense />
                </MudItem>
            }
            else if (type == OperationType.Send || type == OperationType.Receive)
            {
                <MudItem xs="3">
                    <MyMudSelect TItem="long" @bind-Value=@filter.StoreId Label="Со склада" Items=@_fromStores Clearable Dense />
                </MudItem>
                <MudItem xs="3">
                    <MyMudSelect TItem="long" @bind-Value=@filter.ToStoreId Label="На склад" Items=@_toStores Clearable Dense />
                </MudItem>
            }
        </MudGrid>
    </FilterBar>
    <ChildContent>
        <MudTable ServerData="ServerReload" Dense="true" Hover="true" Striped="true" @ref=table RowStyleFunc="new Func<OperationResponse, int, string>(GetRowStyle)">
            <HeaderContent>
                @foreach (var col in Columns.Where(c => c.Visible))
                {
                    <MudTh><MudTableSortLabel SortLabel=@col.PropertyName T="OperationResponse" Style=@col.Style>@col.Title</MudTableSortLabel></MudTh>
                }
                <MudTh Style="width: 100px;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                @foreach (var col in Columns.Where(c => c.Visible))
                {
                    @if (col.PropertyName == nameof(OperationResponse.Code))
                    {
                        <MudTd>@context.Code.ToString().PadLeft(6, '0')</MudTd>
                    }
                    else
                    {
                        <MudTd>@GetValue(context, col.PropertyName, col.StringFormat)</MudTd>
                    }
                }
                <MudTd>
                    <MudStack Row=true AlignItems=AlignItems.Center Style="width: 100%;">
                        <AuthorizeView Roles="User" Context="cont">
                            @if (type != OperationType.Receive)
                            {
                                <ActionButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Tooltip="Редактировать" OnClick=@(() => OpenEditDialogAsync(context)) />
                            }
                        </AuthorizeView>
                        <AuthorizeView Roles="Admin" Context="cont">
                            @if (type == OperationType.Receiving || type == OperationType.ReturnsToSuplier)
                            {
                                <ActionButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Tooltip="Редактировать" OnClick=@(() => OpenEditDialogAsync(context)) />
                            }
                        </AuthorizeView>
                        <ActionButton Icon="@Icons.Material.Filled.Print" Color="Color.Secondary" Tooltip="Печать" OnClick=@(() => OnPrintAsync(context)) />
                        @if (type != OperationType.Receive)
                        {
                            <ActionButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Tooltip="Удалить" OnClick=@(() => OnDeleteAsync(context)) />
                        }
                    </MudStack>
                </MudTd>
            </RowTemplate>
            <FooterContent>
                @foreach (var col in Columns.Where(c => c.Visible))
                {
                    if (col.PropertyName == nameof(OperationResponse.Amount))
                    {
                        <MudTh>@Math.Round(productsAmount, 2)</MudTh>
                    }
                    else if (col.PropertyName == nameof(OperationResponse.Discount))
                    {
                        <MudTh>@Math.Round(productsDiscount, 2)</MudTh>
                    }
                    else if (col.PropertyName == nameof(OperationResponse.ToPay))
                    {
                        <MudTh>@Math.Round(productsToPay, 2)</MudTh>
                    }
                    else if ((type == OperationType.Send || type == OperationType.Receive) && col.PropertyName == nameof(OperationResponse.Amount))
                    {
                        <MudTh>@Math.Round(productsToPay, 2)</MudTh>
                    }
                    else
                    {
                        <MudTh></MudTh>
                    }
                }
                <MudTh Style="width: 100px;"></MudTh>
            </FooterContent>
            <NoRecordsContent>
                <MudText>Нет данных, соответствующих фильтру</MudText>
            </NoRecordsContent>
            <LoadingContent>
                <MudText>Загрузка...</MudText>
            </LoadingContent>
            <PagerContent>
                <MudTablePager InfoFormat="{first_item}-{last_item} из {all_items}" RowsPerPageString="Строк на странице" />
            </PagerContent>
        </MudTable>
    </ChildContent>
</PageContent>


@code {

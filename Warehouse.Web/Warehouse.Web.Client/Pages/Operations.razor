        Columns = await LocalStorage.GetOperationColumns(type);
        filterString = filter.ToString();
        pastYears = DateTime.Now.Year - 2025;
    }

    private string GetRowStyle(OperationResponse p, int row)
    {
        if (p.Type == (int)OperationType.Send && p.IsReceived)
            return "background-color:#c8e6c9; color:#2e7d32;";
        else if (p.Type == (int)OperationType.Send && !p.IsReceived)
            return "background-color:#ffebee; color:#d32f2f;";

        return "";
    }


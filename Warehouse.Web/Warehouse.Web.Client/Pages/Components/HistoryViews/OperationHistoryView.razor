@using System.Text.Json
@using System.Text

@inject HttpClient client

<MudGrid Style="padding: 0 0 10px 0;">
    <MudItem xs="12">
        <MudStack Row="true" AlignItems="AlignItems.End" Justify="Justify.FlexStart">
            <MudText Inline>@Title</MudText>
            <MudText Style="font-weight: bold;">От:</MudText>
            <MudText>@date.ToString("dd.MM.yyyy HH:mm")</MudText>

            <MudText Style="font-weight: bold;">Склад:</MudText>
            <MudText>@StoreName</MudText>


            @if (OperationType == OperationType.Send || OperationType == OperationType.Receive)
            {
                <MudText Style="font-weight: bold;">На склад:</MudText>
                <MudText>@ToStoreName</MudText>
            }
            else
            {
                <MudText Style="font-weight: bold;">Агент:</MudText>
                <MudText>@AgentName</MudText>

                <MudText Style="font-weight: bold;">Скидка:</MudText>
                <MudText>@discountPercentage</MudText>
            }
        </MudStack>
    </MudItem>
    <MudItem xs="12">
        <MudTable T="OperationProductRequest" Items="@productsRequest" TotalItems=@productsRequest.Count() Hover="true" Dense>
            <HeaderContent>
                <MudTh>Наименование</MudTh>
                <MudTh Style="width:150px;">Количество</MudTh>
                <MudTh Style="width:150px;">Цена</MudTh>
                <MudTh Style="width:150px;">Сумма</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Quantity">@context.Quantity</MudTd>
                <MudTd DataLabel="Price">@context.Price.ToString("N2")</MudTd>
                <MudTd>@((context.Quantity * context.Price).ToString("N2"))</MudTd>
            </RowTemplate>
            <FooterContent>
                <MudTh></MudTh>
                <MudTh>@(productsRequest.Sum(x => x.Quantity).ToString("N2"))</MudTh>
                <MudTh></MudTh>
                <MudTh>@(productsRequest.Sum(x => x.Quantity * x.Price).ToString("N2"))</MudTh>
            </FooterContent>

            <NoRecordsContent>
                <MudText>Нет данных, соответствующих фильтру</MudText>
            </NoRecordsContent>
            <LoadingContent>
                <MudText>Загрузка...</MudText>
            </LoadingContent>
            <PagerContent>
                <MudTablePager InfoFormat="{first_item}-{last_item} из {all_items}" RowsPerPageString="Строк на странице" />
            </PagerContent>
        </MudTable>
    </MudItem>
    <MudItem xs="6">
        <MudTextField T="string" @bind-Value=@comment Label="Коментария" Lines="4" Clearable />
    </MudItem>
    @if (OperationType != OperationType.Send && OperationType != OperationType.Receive)
    {
        <MudItem xs="4">
            <MudStack AlignItems="AlignItems.End" Spacing="1">
                <MudText>Сумма:</MudText>
                <MudText>Скидка:</MudText>
                <MudText>Итого:</MudText>
            </MudStack>
        </MudItem>
        <MudItem xs="2">
            <MudStack AlignItems="AlignItems.End" Spacing="1">
                <MudText>@amount.ToString("N2")</MudText>
                <MudText>@discount.ToString("N2")</MudText>
                <MudText>@((amount - discount).ToString("N2"))</MudText>
            </MudStack>
        </MudItem>
    }
</MudGrid>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    string Title => GetTitle();

    [Parameter]
    public string StoreName { get; set; }
    [Parameter]
    public string ToStoreName { get; set; }
    [Parameter]
    public string AgentName { get; set; }

    [Parameter]
    public OperationResponse Operation { get; set; } = new();

    public OperationType OperationType => (OperationType)Operation.Type;

    bool isBuy => OperationType != OperationType.Send && OperationType != OperationType.ReturnsToSuplier && OperationType != OperationType.Shipments;

    string GetTitle()
    {
        if (OperationType == OperationType.Send)
            return "Отправка";
        else if (OperationType == OperationType.Receive)
            return "Получение";
        else if (OperationType == OperationType.Receiving)
            return "Приемки";
        else if (OperationType == OperationType.ReturnsToSuplier)
            return "Возвраты поставщикам";
        else if (OperationType == OperationType.Shipments)
            return "Отгрузки";
        else if (OperationType == OperationType.BuyerReturn)
            return "Возвраты покупателей";
        else if (OperationType == OperationType.Audit)
            return "Ревизия склада";

        return "";
    }

    DateTime date = DateTime.Now;
    decimal discountPercentage;
    decimal amount => productsRequest.Sum(x => x.Quantity * x.Price);
    decimal discount => amount * discountPercentage / 100m;
    long? storeId;
    long? toStoreId;
    long? agentId;
    string? comment;
    long? parentId;

    List<OperationProductRequest> productsRequest = new();

    protected override void OnInitialized()
    {
        date = Operation.Date;
        storeId = Operation.StoreId;
        if (Operation.ToStoreId != 0)
        {
            toStoreId = Operation.ToStoreId;
        }
        agentId = Operation.AgentId;
        discountPercentage = Operation.DiscountPercentage;
        comment = Operation.Comment;

        productsRequest = Operation.Products.Clone().Select(x => new OperationProductRequest
            {
                BuyPrice = x.BuyPrice,
                Manufacturer = x.Manufacturer,
                Name = x.ProductName,
                Price = x.Price,
                ProductId = x.ProductId,
                Quantity = x.Quantity,
                SellPrice = x.SellPrice,
                Unit = x.Unit
            }).OrderBy(x => x.Name).ToList();
    }
}
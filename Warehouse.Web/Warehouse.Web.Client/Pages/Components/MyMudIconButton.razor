

<MudTooltip Text=@Tooltip Color=@Color>
    <MyIconButton Icon=@Icon
        Variant="Variant.Outlined"
        ExtendedSize="Size"
        Color=@Color
        OnClick=@OnClick
        Disabled=Disabled />
</MudTooltip>

@code {
    [Parameter]
    public EventCallback OnClick { get; set; }

    [Parameter]
    public string? Icon { get; set; }

    [Parameter]
    public string? Tooltip { get; set; }

    [Parameter]
    public ExtendedSize Size { get; set; } = ExtendedSize.ExtraSmall;

    [Parameter]
    public Color Color { get; set; } = Color.Primary;

    [Parameter]
    public bool Disabled { get; set; }
}

@page "/audit/products"

@inject HttpClient client

@attribute [Authorize(Roles = "Admin,User")]

<PageContent Title="Ревизия склада (Товары)" @ref=pageContent>
    <ActionBar>
        <AuthorizeView Roles="User">
            <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Primary" StartIcon=@Icons.Material.Filled.Add OnClick="OpenAddDialogAsync">Добавить</MudButton>
        </AuthorizeView>
    </ActionBar>
    <ChildContent>
        <MudTable ServerData="ServerReload" Dense="true" Hover="true" Striped="true" @ref=table CustomHeader="true" HeaderClass="table-head-bordered" Bordered="true">
            <HeaderContent>
                <MudTHeadRow Class="header-centered">
                    <MudTh rowspan="2" Style="width: 100px;">Код</MudTh>
                    <MudTh rowspan="2" Style="max-width: fit-content;">Дата</MudTh>
                    <MudTh rowspan="2">Склад</MudTh>
                    <MudTh colspan="2">Недостача</MudTh>
                    <MudTh colspan="2">Излишки</MudTh>
                    <MudTh rowspan="2" Style="width: 100px;"></MudTh>
                </MudTHeadRow>
                <MudTHeadRow Class="header-centered">
                    <MudTh Style="width: 120px;">Количество</MudTh>
                    <MudTh Style="width: 120px;">Сумма</MudTh>
                    <MudTh Style="width: 120px;">Количество</MudTh>
                    <MudTh Style="width: 120px;">Сумма</MudTh>
                </MudTHeadRow>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Code">@context.Code.ToString().PadLeft(6, '0')</MudTd>
                <MudTd DataLabel="Date">@context.Date.ToString("dd.MM.yyyy HH:mm")</MudTd>
                <MudTd DataLabel="StoreName">@context.StoreName</MudTd>
                <MudTd DataLabel="ShortageCount">@context.ShortageCount</MudTd>
                <MudTd DataLabel="ShortageAmount">@context.ShortageAmount</MudTd>
                <MudTd DataLabel="SurplusCount">@context.SurplusCount</MudTd>
                <MudTd DataLabel="SurplusAmount">@context.SurplusAmount</MudTd>
                <MudTd>
                    <MudStack Row=true AlignItems=AlignItems.Center Style="width: 100%;">
                        <ActionButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Tooltip="Редактировать" OnClick=@(() => OpenEditDialogAsync(context)) />
                        <ActionButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Tooltip="Удалить" OnClick=@(() => OnDeleteAsync(context)) />
                    </MudStack>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText>Нет данных, соответствующих фильтру</MudText>
            </NoRecordsContent>
            <LoadingContent>
                <MudText>Загрузка...</MudText>
            </LoadingContent>
            <PagerContent>
                <MudTablePager InfoFormat="{first_item}-{last_item} из {all_items}" RowsPerPageString="Строк на странице" />
            </PagerContent>
        </MudTable>
    </ChildContent>
</PageContent>


@code {
    private string _buttonText = "ФИО";
    bool IsLoading;
    private MudTable<AuditProductResponse> table;

    PageContent pageContent;
    MudMessageBox _messageBox => pageContent.MessageBox;

    Dictionary<long, string> stores = new();
    Dictionary<long, string> agents = new();
    List<ProductResponse> products = new();

    DialogOptions dialogOptions => new() { MaxWidth = MaxWidth.Large, FullWidth = true, BackdropClick = false };

    object? GetValue(object obj, string propertyName, string? stringFormat = null)
    {
        var prop = obj.GetType().GetProperty(propertyName);
        var value = prop?.GetValue(obj);

        if (value is null)
            return null;

        if (!string.IsNullOrEmpty(stringFormat))
        {
            if (value is IFormattable formattable)
                return formattable.ToString(stringFormat, null);
        }

        return value;
    }

    List<ColumnDefinition> Columns;

    protected override async Task OnInitializedAsync()
    {
        Columns = await LocalStorage.GetAuditProductsColumns();
    }

    private async Task OnDeleteAsync(AuditProductResponse auditResponse)
    {
        var message = await _messageBox.ShowAsync();

        if (message is not null)
        {
            var response = await client.DeleteAsync($"{ApiEndpoints.V1.Operations.Create}/{auditResponse.Id}");
            var result = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Success();
                await table.ReloadServerData();
            }
            else
            {
                Snackbar.Error();
            }
        }
    }

    private async Task OpenEditDialogAsync(AuditProductResponse auditResponse)
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };

        var parameters = new DialogParameters<AddOrEditAuditProductsDialog>
        {
            { x => x.Audit, auditResponse },
            { x => x.Stores, stores },
            { x => x.Products, products },
            { x => x.IsEdit, true }
        };

        var dialog = await DialogService.ShowAsync<AddOrEditAuditProductsDialog>("Редактировать", parameters, dialogOptions);

        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await table.ReloadServerData();
        }
    }

    private async Task OpenAddDialogAsync()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };

        var parameters = new DialogParameters<AddOrEditAuditProductsDialog>
        {
            { x => x.Stores, stores },
            { x => x.Products, products }
        };

        var dialog = await DialogService.ShowAsync<AddOrEditAuditProductsDialog>("Добавить", parameters, dialogOptions);

        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await table.ReloadServerData();
        }
    }

    PagedRequest pagedRequest = new();
    private async Task<TableData<AuditProductResponse>> ServerReload(TableState state, CancellationToken token)
    {
        IsLoading = true;
        StateHasChanged();
        pagedRequest.Filter = $"(Type,6)";

        if (pagedRequest.ResetPage)
        {
            pagedRequest.ResetPage = false;

            if (state.Page != 0)
                table.NavigateTo(0);
        }

        pagedRequest.Refresh(state);

        string content = string.Empty;
        try
        {
            var options = new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                };

            var response = await client.GetAsync($"{ApiEndpoints.V1.Operations.GetAll}?{pagedRequest.ToQuery()}", token);
            content = await response.Content.ReadAsStringAsync();

            var result = await response.Content.ReadFromJsonAsync<AuditProductsResponse>(options);

            if (response.IsSuccessStatusCode && result is not null)
            {
                products = result.Products.OrderBy(x => x.Name).ToList();
                stores = result.Stores.ToDictionary(s => s.Id, s => s.Name);

                return new TableData<AuditProductResponse>
                    {
                        TotalItems = result.Total,
                        Items = result.Items
                    };
            }
        }
        catch (JsonException ex)
        {
            if (ex.Message.StartsWith("'<' is an invalid start of a value"))
            {
                Nav.NavigateTo(Nav.Uri, forceLoad: true);
            }
        }
        finally
        {
            IsLoading = false;

            StateHasChanged();
        }

        return await Task.FromResult(new TableData<AuditProductResponse>
            {
                Items = new List<AuditProductResponse>()
            });
    }
}
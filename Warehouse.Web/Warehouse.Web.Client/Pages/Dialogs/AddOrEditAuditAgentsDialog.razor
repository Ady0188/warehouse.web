@using System.Text.Json
@using System.Text

@inject HttpClient client
@inject IJSRuntime JSRuntime

<MudDialog>
    <DialogContent>
        <MudForm @ref="form">
            <MudGrid Style="padding: 0 0 10px 0;">
                <MudItem xs="12">
                    <MudTable @ref=table Items="@AuditAgents" Dense="true" Hover="@true" Filter="new Func<OperAgentResponse,bool>(FilterFunc)" RowStyleFunc="new Func<OperAgentResponse, int, string>(GetRowStyle)">
                        <ToolBarContent>
                            <MudStack Row="true" AlignItems="AlignItems.End" Justify="Justify.FlexStart">
                                <MudText Inline>@Title</MudText>
                                <MudStack Style="width:175px;">
                                    <MudDateTimePicker Label="От" @bind-Value=@date />
                                </MudStack>
                                <MudSelect T="long?" @bind-Value="storeId" Label="Склад" Required="true" Clearable Style="width:185px;">
                                    @foreach (var store in Stores)
                                    {
                                        <MudSelectItem T="long?" Value="store.Key">@store.Value</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudStack>
                            <MudTextField @bind-Value="searchString" Placeholder="Поиск товара" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Style="margin-top:15px;margin-left:15px;"></MudTextField>
                        </ToolBarContent>
                        <HeaderContent>
                            <MudTh>Наименование</MudTh>
                            <MudTh Style="width:200px;">Текущий</MudTh>
                            <MudTh Style="width:120px;">Фактический</MudTh>
                            <MudTh Style="width:120px;">Разница</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Name">@context.Name</MudTd>
                            <MudTd DataLabel="Plan"><MudStack Row><span>@Math.Abs(context.Plan)</span> <MudSpacer /> <span>@GetTitleRow(context.Plan)</span></MudStack></MudTd>
                            <MudTd DataLabel="Fact">
                                <MudTextField T="decimal" id=@($"input{context.Id}") Value=@context.Fact ValueChanged=@(v => FactChanged(context, v)) @onkeyup="@((e) => HandleInputKeyDown(e, context.Id))" IconSize="Size.Small" Class="mt-0"></MudTextField>
                            </MudTd>
                            <MudTd DataLabel="Molar mass">@context.Difference</MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager />
                        </PagerContent>
                        <EditButtonContent Context="button">
                            <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Edit" Class="pa-0" OnClick="@button.ButtonAction" Disabled="@button.ButtonDisabled" />
                        </EditButtonContent>
                    </MudTable>
                </MudItem>
                <MudItem xs="6">
                    <MudTextField T="string" @bind-Value=@comment Label="Коментария" Lines="4" Clearable />
                </MudItem>
                <MudItem xs="4">
                    <MudStack AlignItems="AlignItems.End" Spacing="1">
                        <MudText><b>Недостача:</b></MudText>
                        <MudText><b>Излишки:</b></MudText>
                    </MudStack>
                </MudItem>
                <MudItem xs="2">
                    <MudStack AlignItems="AlignItems.End" Spacing="1">
                        <MudText>@AuditAgents.Where(x => x.Difference < 0).Sum(x => Math.Abs(x.Difference)).ToString("N2")</MudText>
                        <MudText>@AuditAgents.Where(x => x.Difference > 0).Sum(x => x.Difference).ToString("N2")</MudText>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Закрыть</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled=@(!storeId.HasValue || !AuditAgents.Any(x => x.Difference != 0))>Сохранить</MudButton>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public string Title { get; set; } = "Ревизия";

    [Parameter]
    public AuditAgentResponse Audit { get; set; }

    [Parameter]
    public bool IsEdit { get; set; }

    [Parameter]
    public Dictionary<long, string> Stores { get; set; }

    [Parameter]
    public List<AgentResponse> Agents { get; set; }

    public List<AgentResponse> _agentsList { get; set; }

    private string searchString = "";

    public List<OperAgentResponse> AuditAgents = new();

    private MudForm form;
    private MudTable<OperAgentResponse> table;

    DateTime date = DateTime.Now;
    long? storeId;
    string? comment;

    List<OrderAgentRequest> agentsRequest = new();

    string GetTitleRow(decimal data)
    {
        if (data == 0)
        {
            return string.Empty;
        }

        return data > 0 ? "(предоплата)" : "(долг)";
    }

    private string GetRowStyle(OperAgentResponse p, int row)
    {
        // пример: выделяем пустые позиции красным фоном
        if (p.Changed)
            return "background-color:#ffebee; color:#d32f2f;"; // светло-красный

        return ""; // без изменений
    }

    private async Task Submit()
    {
        await form.Validate();

        if (!form.IsValid)
        {
            return;
        }

        bool isSubmitSuccess = false;

        decimal amount = AuditAgents.Sum(x => x.Difference);
        decimal discountPercentage = 0;

        agentsRequest = AuditAgents.Select(x => new OrderAgentRequest
        {
            Id = x.Id,
            Name = x.Name,
            Debt = x.Fact,
            Difference = x.Difference
        }).ToList();

        if (IsEdit)
        {
            var updateRequest = new UpdateOrderRequest(date.ToString("ddMMyyyyHHmm"), 0, storeId.Value, 0, amount, comment, 2, agentsRequest);

            var response = await client.PutAsync($"{ApiEndpoints.V1.Orders.Create}/{Audit.Id}", updateRequest.ToStringContent());
            var result = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Success();
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Error();
            }
        }
        else
        {
            var addRequest = new CreateOrderRequest(date.ToString("ddMMyyyyHHmm"), 0, storeId!.Value, 0, amount, comment, 2, agentsRequest);

            var response = await client.PostAsync(ApiEndpoints.V1.Orders.Create, addRequest.ToStringContent());
            var result = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Success();
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Error();
            }
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private void Reset()
    {
        date = DateTime.Now;
        storeId = default;
        comment = default;

        if (Stores.Count() == 1)
            storeId = Stores.First().Key;
    }

    protected override void OnInitialized()
    {
        _agentsList = Agents.Clone();

        if (IsEdit)
        {
            var _auditProducts = Audit.Agents.Clone();
            date = Audit.Date;
            storeId = Audit.StoreId;
            comment = Audit.Comment;

            AuditAgents = _auditProducts;

            foreach (var x in _agentsList.ToList())
            {
                var auditAgent = AuditAgents.FirstOrDefault(a => a.Id == x.Id);
                if (auditAgent is not null)
                {
                    auditAgent.Plan = x.Debts.DebtOnEnd;
                    auditAgent.Fact = auditAgent.Fact;
                    var _diff = auditAgent.Difference;
                    auditAgent.Difference = (auditAgent.Plan - auditAgent.Fact) * -1;
                    auditAgent.Changed = _diff != auditAgent.Difference;
                }
                else
                    AuditAgents.Add(new OperAgentResponse
                    {
                        Id = x.Id,
                        Plan = x.Debts.DebtOnEnd,
                        Fact = x.Debts.DebtOnEnd,
                        Address = x.Address,
                        Comment = x.Comment,
                        ManagerId = x.ManagerId,
                        ManagerName = x.ManagerName,
                        ManagerPhone = x.ManagerPhone,
                        Name = x.Name,
                        Phone = x.Phone,
                        StoreId = x.StoreId,
                        StoreName = x.StoreName,
                        Changed = true
                    });
            }
        }
        else
        {
            Reset();
            AuditAgents = _agentsList.Select(x =>
            {
                return new OperAgentResponse
                {
                    Id = x.Id,
                        Plan = x.Debts.DebtOnEnd,
                        Fact = x.Debts.DebtOnEnd,
                        Address = x.Address,
                        Comment = x.Comment,
                        ManagerId = x.ManagerId,
                        ManagerName = x.ManagerName,
                        ManagerPhone = x.ManagerPhone,
                        Name = x.Name,
                        Phone = x.Phone,
                        StoreId = x.StoreId,
                        StoreName = x.StoreName
                };
            }).ToList();
        }

        filteredItemsCount = AuditAgents.Count();
        indexes = new();
        ids = new();

        int ind = 0;
        foreach (var item in AuditAgents)
        {
            ind++;
            ids.Add(ind, item.Id);
            indexes.Add(item.Id, ind);
        }
    }


    private bool FilterFunc(OperAgentResponse element)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    }

    private void FactChanged(OperAgentResponse response, decimal value)
    {
        response.Fact = value;
        response.Difference = (response.Plan - value) * -1;
    }

    int filteredItemsCount;
    Dictionary<int, long> ids;
    Dictionary<long, int> indexes;
    private async Task HandleInputKeyDown(KeyboardEventArgs e, long currentId)
    {
        if (e.Key != "Enter")
            return;

        const int pageSize = 10;

        var items = table.FilteredItems.ToList();
        var total = items.Count;

        if (total == 0)
            return;

        if (filteredItemsCount != total || !indexes.ContainsKey(currentId))
        {
            indexes = new Dictionary<long, int>();
            ids = new Dictionary<int, long>();

            for (int i = 0; i < items.Count; i++)
            {
                var idx = i + 1;
                ids[idx] = items[i].Id;
                indexes[items[i].Id] = idx;
            }

            filteredItemsCount = total;
        }

        if (!indexes.TryGetValue(currentId, out var index))
        {
            index = indexes.Values.First();
        }

        int totalPages = (total + pageSize - 1) / pageSize; // ceil(total / pageSize)
        int currentPage = table.CurrentPage;                 // предполагается 0-based
        int indexPage = (index - 1) / pageSize;             // 0-based страница для index

        int firstIndex = indexes.Values.Min();
        int lastIndex = indexes.Values.Max();

        var nextIndex = index == lastIndex ? firstIndex : index + 1;
        int nextIndexPage = (nextIndex - 1) / pageSize;

        if (nextIndexPage != currentPage)
        {
            table.NavigateTo(nextIndexPage);

            await Task.Yield();
        }

        if (ids.TryGetValue(nextIndex, out var idToFocus))
        {
            await JSRuntime.InvokeVoidAsync("BlazorFocusHelpers.focusAndSelect", $"input{idToFocus}");
        }
    }
}
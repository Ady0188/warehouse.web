@using System.Text.Json
@using System.Text

@inject HttpClient client
@inject IJSRuntime JSRuntime

<MudDialog>
    <DialogContent>
        <MudForm @ref="form">
            <MudGrid Style="padding: 0 0 10px 0;">
                <MudItem xs="12">
                    <MudTable @ref=table Items="@AuditProducts" Dense="true" Hover="@true" Filter="new Func<OperationProductResponse,bool>(FilterFunc)" RowStyleFunc="new Func<OperationProductResponse, int, string>(GetRowStyle)">
                        <ToolBarContent>
                            <MudStack Row="true" AlignItems="AlignItems.End" Justify="Justify.FlexStart">
                                <MudText Inline>@Title</MudText>
                                <MudStack Style="width:175px;">
                                    <MudDateTimePicker Label="От" @bind-Value=@date />
                                </MudStack>
                                <MudSelect T="long?" @bind-Value="storeId" Label="Склад" Required="true" Clearable Style="width:185px;">
                                    @foreach (var store in Stores)
                                    {
                                        <MudSelectItem T="long?" Value="store.Key">@store.Value</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudStack>
                            <MudTextField @bind-Value="searchString" Placeholder="Поиск товара" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Style="margin-top:15px;margin-left:15px;"></MudTextField>
                        </ToolBarContent>
                        <HeaderContent>
                            <MudTh>Наименование</MudTh>
                            <MudTh>Производитель</MudTh>
                            <MudTh Style="width:120px;">Цена продажа</MudTh>
                            <MudTh Style="width:120px;">Текущий остаток</MudTh>
                            <MudTh Style="width:120px;">Фактический остаток</MudTh>
                            <MudTh Style="width:120px;">Разница</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="ProductName">@context.ProductName</MudTd>
                            <MudTd DataLabel="Manufacturer">@context.Manufacturer</MudTd>
                            <MudTd DataLabel="SellPrice">@context.SellPrice</MudTd>
                            <MudTd DataLabel="Plan">@context.Plan</MudTd>
                            <MudTd DataLabel="Fact">
                                <MudTextField T="long" id=@($"input{context.Id}") Value=@context.Fact ValueChanged=@(v => FactChanged(context, v)) @onkeyup="@((e) => HandleInputKeyDown(e, context.Id))" IconSize="Size.Small" Class="mt-0"></MudTextField>
                            </MudTd>
                            <MudTd DataLabel="Molar mass">@context.Difference</MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager />
                        </PagerContent>
                        <EditButtonContent Context="button">
                            <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Edit" Class="pa-0" OnClick="@button.ButtonAction" Disabled="@button.ButtonDisabled" />
                        </EditButtonContent>
                    </MudTable>
                </MudItem>
                <MudItem xs="6">
                    <MudTextField T="string" @bind-Value=@comment Label="Коментария" Lines="4" Clearable />
                </MudItem>
                <MudItem xs="4">
                    <MudStack AlignItems="AlignItems.End" Spacing="1">
                        <MudText><b>Недостача</b> количество:</MudText>
                        <MudText>сумма:</MudText>
                        <MudText><b>Излишки</b> количество:</MudText>
                        <MudText>сумма:</MudText>
                    </MudStack>
                </MudItem>
                <MudItem xs="2">
                    <MudStack AlignItems="AlignItems.End" Spacing="1">
                        <MudText>@AuditProducts.Where(x => x.Difference < 0).Sum(x => Math.Abs(x.Difference))</MudText>
                        <MudText>@AuditProducts.Where(x => x.Difference < 0).Sum(x => Math.Abs(x.Difference) * x.SellPrice).ToString("N2")</MudText>
                        <MudText>@AuditProducts.Where(x => x.Difference > 0).Sum(x => x.Difference)</MudText>
                        <MudText>@AuditProducts.Where(x => x.Difference > 0).Sum(x => x.Difference * x.SellPrice).ToString("N2")</MudText>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Закрыть</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled=@(!storeId.HasValue || !AuditProducts.Any(x => x.Difference != 0))>Сохранить</MudButton>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public string Title { get; set; } = "Ревизия";

    [Parameter]
    public AuditProductResponse Audit { get; set; }

    [Parameter]
    public bool IsEdit { get; set; }

    [Parameter]
    public Dictionary<long, string> Stores { get; set; }

    [Parameter]
    public List<ProductResponse> Products { get; set; }

    public List<ProductResponse> _productsList { get; set; }

    private string searchString = "";

    public List<OperationProductResponse> AuditProducts = new();

    private MudForm form;
    private MudTable<OperationProductResponse> table;

    DateTime date = DateTime.Now;
    long? storeId;
    string? comment;

    List<OperationProductRequest> productsRequest = new();

    private string GetRowStyle(OperationProductResponse p, int row)
    {
        // пример: выделяем пустые позиции красным фоном
        if (p.Changed)
            return "background-color:#ffebee; color:#d32f2f;"; // светло-красный

        return ""; // без изменений
    }

    private async Task Submit()
    {
        await form.Validate();

        if (!form.IsValid)
        {
            return;
        }

        bool isSubmitSuccess = false;

        decimal amount = AuditProducts.Sum(x => x.Difference * x.SellPrice);
        decimal discountPercentage = 0;

        productsRequest = AuditProducts.Select(x => new OperationProductRequest
        {
            ProductId = x.ProductId,
            Code = x.Code,
            Name = x.ProductName,
            Unit = x.Unit,
            Manufacturer = x.Manufacturer,
            Quantity = (int)x.Fact, //x.Difference,
            Price = x.SellPrice,
            BuyPrice = x.BuyPrice,
            SellPrice = x.SellPrice,
            Difference = (int)x.Difference
        }).ToList();

        var firstTest = productsRequest.FirstOrDefault(x => x.Name == "Асвижител Freshener 360ml");

        if (IsEdit)
        {
            var updateRequest = new UpdateOperationRequest(date.ToString("ddMMyyyyHHmm"), amount, discountPercentage, 6, 0, storeId!.Value, 0, comment, productsRequest);

            var response = await client.PutAsync($"{ApiEndpoints.V1.Operations.Create}/{Audit.Id}", updateRequest.ToStringContent());
            var result = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Success();
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Error();
            }
        }
        else
        {
            var addRequest = new CreateOperationRequest(date.ToString("ddMMyyyyHHmm"), amount, discountPercentage, 6, storeId!.Value, 0, comment, productsRequest);

            var response = await client.PostAsync(ApiEndpoints.V1.Operations.Create, addRequest.ToStringContent());
            var result = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Success();
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Error();
            }
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private void Reset()
    {
        date = DateTime.Now;
        storeId = default;
        comment = default;

        if (Stores.Count() == 1)
            storeId = Stores.First().Key;
    }

    protected override async Task OnInitializedAsync()
    {
        _productsList = Products.Clone();

        if (IsEdit)
        {
            var _auditProducts = Audit.Products.Clone();
            date = Audit.Date;
            storeId = Audit.StoreId;
            comment = Audit.Comment;

            var remainsResponse = await client.GetAsync($"{ApiEndpoints.V1.Reports.Remains}?dateTime={date.ToString("ddMMyyyyHHmmss")}");
            var remainsResult = await remainsResponse.Content.ReadFromJsonAsync<RemainsesResponse>();

            var thisStoreRemains = remainsResult!.StoreRemains.FirstOrDefault(x => x.Key == storeId).Value ?? new List<RemainsResponse>();

            foreach (var item in _productsList)
            {
                var remains = thisStoreRemains.FirstOrDefault(x => x.ProductId == item.Id);

                if (remains is null)
                {
                    item.StoresRemains[storeId.Value] = 0;
                    continue;
                }

                item.StoresRemains[storeId.Value] = remains.Count;
            }

            AuditProducts = _auditProducts;

            foreach (var x in _productsList.ToList())
            {
                var storeRemains = x.StoresRemains.FirstOrDefault(r => r.Key == storeId);
                var value = storeRemains.Equals(default(KeyValuePair<long, decimal>))
                ? 0
                : storeRemains.Value;

                var auditProduct = AuditProducts.FirstOrDefault(p => p.ProductId == x.Id);
                if (auditProduct is not null)
                {
                    auditProduct.Plan = value;
                    auditProduct.Fact = auditProduct.Quantity;
                    var _diff = auditProduct.Difference;
                    auditProduct.Difference = (auditProduct.Plan - auditProduct.Fact) * -1;
                    auditProduct.Changed = _diff != auditProduct.Difference;
                }
                else
                    AuditProducts.Add(new OperationProductResponse
                        {
                            Id = x.Id,
                            Code = x.Code,
                            BuyPrice = x.BuyPrice,
                            SellPrice = x.SellPrice,
                            Manufacturer = x.Manufacturer,
                            ProductName = x.Name,
                            ProductId = x.Id,
                            Plan = value,
                            Fact = value,
                            Unit = x.Unit,
                            Changed = true
                        });
            }
        }
        else
        {
            Reset();
            AuditProducts = _productsList.Select(x =>
            {
                var storeRemains = x.StoresRemains.FirstOrDefault(r => r.Key == storeId);
                var value = storeRemains.Equals(default(KeyValuePair<long, decimal>))
                ? 0
                : storeRemains.Value;

                return new OperationProductResponse
                {
                    Id = x.Id,
                    Code = x.Code,
                    BuyPrice = x.BuyPrice,
                    SellPrice = x.SellPrice,
                    Manufacturer = x.Manufacturer,
                    ProductName = x.Name,
                    ProductId = x.Id,
                    Plan = value,
                    Fact = value,
                    Unit = x.Unit
                };
            }).ToList();
        }

        AuditProducts = AuditProducts.OrderBy(x => x.ProductName).ToList();

        filteredItemsCount = AuditProducts.Count();
        indexes = new();
        ids = new();

        int ind = 0;
        foreach (var item in AuditProducts)
        {
            ind++;
            ids.Add(ind, item.Id);
            indexes.Add(item.Id, ind);
        }
    }


    private bool FilterFunc(OperationProductResponse element)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.ProductName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    }

    private void FactChanged(OperationProductResponse response, long value)
    {
        response.Fact = value;
        response.Difference = (response.Plan - value) * -1;
    }

    int filteredItemsCount;
    Dictionary<int, long> ids;
    Dictionary<long, int> indexes;
    private async Task HandleInputKeyDown(KeyboardEventArgs e, long currentId)
    {
        if (e.Key != "Enter")
            return;

        const int pageSize = 10;

        var items = table.FilteredItems.ToList();
        var total = items.Count;

        if (total == 0)
            return;

        if (filteredItemsCount != total || !indexes.ContainsKey(currentId))
        {
            indexes = new Dictionary<long, int>();
            ids = new Dictionary<int, long>();

            for (int i = 0; i < items.Count; i++)
            {
                var idx = i + 1;
                ids[idx] = items[i].Id;
                indexes[items[i].Id] = idx;
            }

            filteredItemsCount = total;
        }

        if (!indexes.TryGetValue(currentId, out var index))
        {
            index = indexes.Values.First();
        }

        int totalPages = (total + pageSize - 1) / pageSize; // ceil(total / pageSize)
        int currentPage = table.CurrentPage;                 // предполагается 0-based
        int indexPage = (index - 1) / pageSize;             // 0-based страница для index

        int firstIndex = indexes.Values.Min();
        int lastIndex = indexes.Values.Max();

        var nextIndex = index == lastIndex ? firstIndex : index + 1;
        int nextIndexPage = (nextIndex - 1) / pageSize;

        if (nextIndexPage != currentPage)
        {
            table.NavigateTo(nextIndexPage);

            await Task.Yield();
        }

        if (ids.TryGetValue(nextIndex, out var idToFocus))
        {
            await JSRuntime.InvokeVoidAsync("BlazorFocusHelpers.focusAndSelect", $"input{idToFocus}");
        }
    }
}
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {







    private AppSettings _appSettings = new AppSettings();

    protected override async Task OnAfterRenderAsync(bool isFirstRender)
    {
        if (isFirstRender)
        {
            _appSettings = await GetSettings();

            _drawerOpen = true;
            CustomTheme = ThemeStorage.GetTheme(_appSettings.ThemeIndex);
            StateHasChanged();
        }
    }

    async Task SetMenu(MenuType menu)
    {
        _appSettings.MenuType = menu;
        _settingsDrawerOpen = false;

        await SetSettings(_appSettings);
    }

    private async Task ToggleTheme()
    {
        _appSettings.IsDarkTheme = !_appSettings.IsDarkTheme;

        await SetSettings(_appSettings);
    }

    private async Task SetSettings(AppSettings settings)
    {
        var json = System.Text.Json.JsonSerializer.Serialize(settings);
        await LocalStorage.SetItemAsync("appSettings", json);
    }

    private async Task<AppSettings> GetSettings()
    {
        var settings = await LocalStorage.GetItemAsStringAsync("appSettings");

        if (!string.IsNullOrEmpty(settings))
        {
            var json = System.Text.Json.JsonSerializer.Deserialize<string>(settings)!;
            return System.Text.Json.JsonSerializer.Deserialize<AppSettings>(json)!;
        }

        return new AppSettings();
    }


    private MudTheme CustomTheme = ThemeStorage.GetTheme(0);

    private async Task ChangeTheme(ThemeItem item)
    {
        CustomTheme = item.Theme;
        _appSettings.ThemeIndex = item.Index;// ThemeStorage.SetTheme(item.Name);
        await SetSettings(_appSettings);
        StateHasChanged();
    }

    private bool _drawerOpen = false;
    private bool _settingsDrawerOpen = false;

    private void SettingsDrawerToggle()
    {
        _settingsDrawerOpen = !_settingsDrawerOpen;
    }

    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    public class ThemeItem
    {
        public string Name { get; set; } = "";
        public MudTheme Theme { get; set; } = default!;
        public string PrimaryColor { get; set; } = "";
        public int Index { get; set; }
    }

    static readonly List<ThemeItem> ThemeList = new()
    {
        new ThemeItem
        {
            Name = "Синий стальной",
            Theme = ThemeStorage.GetTheme(0),
            PrimaryColor = ThemeStorage.GetTheme(0).PaletteLight.Primary.ToString(),
            Index = 0
        },

@page "/Account/employees"

@using Warehouse.Web.Client.Helpers
@using Warehouse.Web.Client.Pages.Components

<PageContent Title="Менеджеры" @ref=pageContent>
    <ActionBar>
        <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Primary" StartIcon=@Icons.Material.Filled.Add>Добавить</MudButton>
    </ActionBar>
    <ChildContent>
        <MudTable ServerData="ServerReload" Dense="true" Hover="true" Striped="true" @ref=table>
            <HeaderContent>
                @foreach (var col in Columns.Where(c => c.Visible))
                {
                    <MudTh><MudTableSortLabel SortLabel=@col.PropertyName T="ApplicationUser" Style=@col.Style>@col.Title</MudTableSortLabel></MudTh>
                }
                <MudTh Style="width: 100px;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                @foreach (var col in Columns.Where(c => c.Visible))
                {
                    <MudTd>@GetValue(context, col.PropertyName, col.StringFormat)</MudTd>
                }
                <MudTd>
                    <MudStack Row=true AlignItems=AlignItems.Center Style="width: 100%;">
                        <MudTooltip Text="Редактировать">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size=Size.Small Variant=Variant.Outlined
                            Color="Color.Primary" />
                        </MudTooltip>

                        <MudTooltip Text="Удалить">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size=Size.Small Variant=Variant.Outlined
                            Color="Color.Error" />
                        </MudTooltip>
                    </MudStack>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText>Нет данных, соответствующих фильтру</MudText>
            </NoRecordsContent>
            <LoadingContent>
                <MudText>Загрузка...</MudText>
            </LoadingContent>
            <PagerContent>
                <MudTablePager InfoFormat="{first_item}-{last_item} из {all_items}" RowsPerPageString="Строк на странице" />
            </PagerContent>
        </MudTable>
    </ChildContent>
</PageContent>

@code {
